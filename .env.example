# Docker Compose defaults
FRONTEND_PORT=6767

# --- PostgreSQL (database) ---
# ExcaliDash is PostgreSQL-only. These power the bundled "postgres" service in
# docker-compose.yml and are composed into DATABASE_URL below.
# IMPORTANT: change POSTGRES_PASSWORD to a strong value before deploying.
POSTGRES_DB=excalidash
POSTGRES_USER=excalidash
POSTGRES_PASSWORD=change_me_strong_password
# Host port the local database is published on (docker-compose.yml only).
POSTGRES_PORT=5432

# Connection string used by the backend (Prisma). With the bundled postgres
# service the host is the service name "postgres". To use an external/managed
# PostgreSQL instead, set DATABASE_URL to your provider's URL (the POSTGRES_*
# values above are then only used by the local postgres service, which you can
# remove from the compose file).
DATABASE_URL=postgresql://excalidash:change_me_strong_password@postgres:5432/excalidash?schema=public

PORT=8000
NODE_ENV=production
AUTH_MODE=local
FRONTEND_URL=http://localhost:6767

# Keep false for direct/local access. Set to 1 only when every request reaches
# the backend through the trusted frontend Nginx/proxy path.
TRUST_PROXY=false

# Leave false when an external gateway already redirects HTTP to HTTPS.
ENFORCE_HTTPS_REDIRECT=false

# Optional for a single backend container: the Docker entrypoint generates and
# persists secrets in the backend volume. Set all three for portable or
# multi-instance deployments.
JWT_SECRET=
CSRF_SECRET=
API_KEY_SECRET=

# Backend payload/import limits (MiB unless the name is a count).
MAX_UPLOAD_MB=250
MAX_JSON_BODY_MB=100
MAX_URLENCODED_BODY_MB=100
MAX_SOCKET_PAYLOAD_MB=100
MAX_IMPORT_DRAWING_MB=100
MAX_IMPORT_MANIFEST_MB=10
MAX_IMPORT_TOTAL_EXTRACTED_MB=500
MAX_DATA_URL_MB=100
MAX_IMPORT_ARCHIVE_ENTRIES=10000
MAX_IMPORT_COLLECTIONS=2000
MAX_IMPORT_DRAWINGS=10000

# --- Curated Excalidraw library packs (foundation for the future MCP server) ---
# CORE_PACK + SPECIALIZED_PACK are curated, always preferred. PUBLIC_SEARCH
# covers the full official Excalidraw catalog (read-only, allowlisted host only).
# Only the official Excalidraw catalog host is ever fetched; arbitrary URLs are
# rejected regardless of the values below.
EXCALIDRAW_LIBRARIES_CATALOG_URL=https://raw.githubusercontent.com/excalidraw/excalidraw-libraries/main/libraries.json
EXCALIDRAW_LIBRARIES_BASE_URL=https://raw.githubusercontent.com/excalidraw/excalidraw-libraries/main/libraries
# Where cached .excalidrawlib files are written (mount a persistent volume here).
LIBRARY_CACHE_DIR=/app/data/libraries
LIBRARY_REFRESH_INTERVAL_HOURS=24
LIBRARY_DOWNLOAD_TIMEOUT_MS=15000
LIBRARY_DOWNLOAD_MAX_MB=25
# Set to false to disable PUBLIC_SEARCH (curated packs still work).
LIBRARY_PUBLIC_SEARCH_ENABLED=true
LIBRARY_PUBLIC_SEARCH_MAX_RESULTS=25
# Refresh the official catalog + reseed packs on backend startup.
LIBRARY_AUTO_REFRESH_ON_START=true

# --- ExcaliDash MCP server (/mcp) ---
# Real MCP endpoint authenticated by Bearer exd_ API keys: 25 drawing tools +
# 25 auto-discovered MCP prompts (/mcp__excalidash__*). 25 Claude Code skills
# install separately (packages/excalidash-claude-skills).
MCP_ENABLED=true
MCP_ENDPOINT_PATH=/mcp
# Minimum quality score (0-100) before a drawing is saved as final.
MCP_MIN_DRAWING_SCORE=95
MCP_MAX_REPAIR_ATTEMPTS=5
# Allow saving below-minimum drawings explicitly as drafts.
MCP_ALLOW_LOW_SCORE_DRAFT=true
MCP_MAX_ELEMENTS=5000
MCP_MAX_EXPORT_MB=100
# curated | all | core | specialized | public  (which packs search returns)
MCP_DEFAULT_LIBRARY_MODE=curated
# off | curated | required  (how strictly library/icon usage is scored)
#   off      = never flag missing library usage
#   curated  = recommended; on demand via lint_drawing/score_drawing flags
#   required = a rich diagram with no library/icon items is a hard blocker
MCP_LIBRARY_MODE=curated
MCP_PUBLIC_SEARCH_ENABLED=false
MCP_RATE_LIMIT_WINDOW_SECONDS=900
MCP_RATE_LIMIT_MAX=300
# Validate the Origin header for browser clients (non-browser clients send none).
MCP_VALIDATE_ORIGIN=true

# Frontend Nginx runtime configuration.
BACKEND_URL=backend:8000
NGINX_CLIENT_MAX_BODY_SIZE=250M
NGINX_PROXY_CONNECT_TIMEOUT=300s
NGINX_PROXY_SEND_TIMEOUT=300s
NGINX_PROXY_READ_TIMEOUT=300s
NGINX_WEBSOCKET_READ_TIMEOUT=3600s
NGINX_WEBSOCKET_SEND_TIMEOUT=3600s

# docker-compose.prod.yml image overrides.
EXCALIDASH_BACKEND_IMAGE=zimengxiong/excalidash-backend
EXCALIDASH_FRONTEND_IMAGE=zimengxiong/excalidash-frontend
EXCALIDASH_IMAGE_TAG=latest
