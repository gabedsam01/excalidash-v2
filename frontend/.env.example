# Frontend Environment Variables
# Use /api for both development (proxied by Vite) and production (proxied by nginx)
# This avoids CORS issues as requests stay same-origin
VITE_API_URL=/api

# The variables below are runtime settings for the production Nginx container,
# not Vite build variables.
BACKEND_URL=backend:8000
NGINX_CLIENT_MAX_BODY_SIZE=250M
NGINX_PROXY_CONNECT_TIMEOUT=300s
NGINX_PROXY_SEND_TIMEOUT=300s
NGINX_PROXY_READ_TIMEOUT=300s
NGINX_WEBSOCKET_READ_TIMEOUT=3600s
NGINX_WEBSOCKET_SEND_TIMEOUT=3600s
